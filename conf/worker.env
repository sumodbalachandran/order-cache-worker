# Order Cache Worker — default environment variables
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

CONSUMER_GROUP=join_workers
CONSUMER_NAME=worker-1

BATCH_SIZE=100
BLOCK_MS=2000
MAX_RETRIES=3
PENDING_CHECK_INTERVAL=30
CACHE_TTL_SECONDS=86400

DEBOUNCE_ENABLED=true
DEBOUNCE_INTERVAL_MS=50

LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=
LOG_MAX_BYTES=104857600
LOG_BACKUP_COUNT=5

OTEL_ENABLED=true
OTEL_SERVICE_NAME=order-cache-worker
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
OTEL_SAMPLE_RATE=0.1

METRICS_ENABLED=true
METRICS_PORT=8000
HEALTH_PORT=8001

DEBUG_MODE=false
DEBUG_PORT=8002
